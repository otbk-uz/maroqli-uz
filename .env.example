# ==========================================================
#  MAROQLI.uz — Muhit o'zgaruvchilari (namuna)
#  Bu faylni nusxalab `.env.local` yarating va qiymatlarni to'ldiring.
#  .env.local hech qachon GitHub'ga yuklanmaydi (.gitignore da).
# ==========================================================

# --- Supabase ---
# Studio → Settings → API dan olinadi
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# MAXFIY! Faqat serverda ishlatiladi, mijozga hech qachon ketmaydi:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Telegram bot (to'lov va turnir boti) ---
# @BotFather dan olinadi. Kodga hech qachon yozmang!
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Webhook xavfsizligi: tasodifiy uzun satr (masalan: openssl rand -hex 32)
# Telegram setWebhook da secret_token sifatida beriladi va har so'rovda tekshiriladi
TELEGRAM_WEBHOOK_SECRET=

# To'lov qabul qilinadigan karta (kodda emas, shu yerda)
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_HOLDER=

# --- Admin panel ---
# Server tomonda tekshiriladigan admin login/parol (kodda emas!)
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Admin sessiya cookie'sini imzolash kaliti (tasodifiy uzun satr)
ADMIN_SESSION_SECRET=

# --- Mux (video/stream) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# --- Cloudflare Stream (turnir jonli efiri, faqat admin) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# --- Django backend (agar ishlatilsa) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
